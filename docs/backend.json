
{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Represents a baseball player and their metadata.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "number": { "type": "number" },
        "announcementAudioUrl": { "type": "string" },
        "songs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "videoId": { "type": "string" },
              "startAt": { "type": "number" }
            }
          }
        }
      },
      "required": ["name", "number"]
    },
    "GameWin": {
      "title": "Game Win",
      "description": "Represents the status (won, cancelled, etc.) of a specific baseball game.",
      "type": "object",
      "properties": {
        "won": { "type": "boolean" },
        "cancelled": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["updatedAt"]
    },
    "GameStats": {
      "title": "Game Stats",
      "description": "Stats for all players and team scores for a specific game.",
      "type": "object",
      "properties": {
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" },
        "playerStats": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "ab": { "type": "number" },
              "h": { "type": "number" },
              "r": { "type": "number" },
              "rbi": { "type": "number" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": { "$ref": "#/backend/entities/Player" },
      "description": "Collection of players in the team."
    },
    "/game_wins/{gameId}": {
      "schema": { "$ref": "#/backend/entities/GameWin" },
      "description": "Collection storing outcomes for specific games."
    },
    "/game_stats/{gameId}": {
      "schema": { "$ref": "#/backend/entities/GameStats" },
      "description": "Collection storing per-game player stats and scores."
    }
  }
}
